{
  "name": "backend",
  "version": "1.0.0",
  "description": "Course search backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "demo": "ts-node-dev --no-respawn --transpile-only src/demo.ts",
    "format": "prettier --write src",
    "format:check": "prettier --check src"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.39",
    "ai": "^6.0.108",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "openai": "^4.52.7",
    "pg": "^8.12.0",
    "pgvector": "^0.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "chalk": "^4.1.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "prettier": "^3.8.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
